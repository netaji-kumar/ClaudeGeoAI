# ArcGIS Enterprise / Portal connection
ARCGIS_URL=https://your-enterprise.domain.com/portal
ARCGIS_USERNAME=your_username
ARCGIS_PASSWORD=your_password

# Optional: explicit profile name (defaults to "default")
ARCGIS_PROFILE=default

# Optional: verify SSL certificates (set to "false" for self-signed certs)
ARCGIS_VERIFY_SSL=true

# Optional: connection timeout in seconds
ARCGIS_TIMEOUT=30
